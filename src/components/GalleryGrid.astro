---
import { Image } from '@unpic/astro';

const { items, galleryId = 'gallery' } = Astro.props;

function getImageSize(w: number | undefined, h: number | undefined) {
  if (w && h) {
    const targetW = Math.min(800, w);
    return { w: targetW, h: Math.round(h * (targetW / w)) };
  }
  return { w: undefined, h: undefined };
}
---

<div class="gallery-grid pswp-gallery" id={galleryId}>
  {items.map((item) => {
    const size = getImageSize(item.width, item.height);
    return (
      <a
        href={`${item.imageUrl}${item.imageUrl.includes('?') ? '&' : '?'}tr=w-1600`}
        data-pswp-width={size.w ?? 0}
        data-pswp-height={size.h ?? 0}
        class="gallery-card"
      >
        {item.imageUrl && (
          <Image
            src={item.imageUrl}
            width={400}
            height={300}
            alt={item.alt}
            layout="constrained"
            loading="lazy"
            decoding="async"
            cdn="cloudflare"
            options={{ cloudflare: { domain: "media.quofai.org" } }}
          />
        )}
      </a>
    );
  })}
</div>

<script>
  import PhotoSwipeLightbox from 'photoswipe/lightbox';
  import 'photoswipe/style.css';

  const instances = [];

  function initLightboxes() {
    const galleries = document.querySelectorAll('.pswp-gallery');

    galleries.forEach((gallery) => {
      const id = gallery.id;
      if (!id) return;

      const cards = gallery.querySelectorAll('a.gallery-card');

      cards.forEach((a) => {
        if (a.dataset.pswpWidth === '0' || a.dataset.pswpHeight === '0') {
          const img = new Image();
          img.onload = () => {
            a.dataset.pswpWidth = String(img.naturalWidth);
            a.dataset.pswpHeight = String(img.naturalHeight);
          };
          img.src = a.href;
        }
      });

      const lightbox = new PhotoSwipeLightbox({
        gallery: `#${id}`,
        children: 'a',

        initialZoomLevel: 'fill',
        secondaryZoomLevel: (z) => z.fit,
        maxZoomLevel: (z) => z.fill * 2,

        pswpModule: () => import('photoswipe'),
      });

      instances.push(lightbox);
      lightbox.init();
    });
  }

  document.addEventListener('astro:before-swap', () => {
    instances.forEach((lb) => lb.destroy());
    instances.length = 0;
  });

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initLightboxes);
  } else {
    initLightboxes();
  }
</script>