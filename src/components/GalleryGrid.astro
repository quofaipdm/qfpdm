---
import { Image } from '@unpic/astro';

const { items, galleryId = 'gallery' } = Astro.props;

function getImageSize(w: number | undefined, h: number | undefined) {
  if (w && h) {
    const targetW = Math.min(800, w);
    return { w: targetW, h: Math.round(h * (targetW / w)) };
  }
  return { w: undefined, h: undefined };
}
---

<div class="gallery-grid pswp-gallery" id={galleryId}>
  {items.map((item) => {
    const size = getImageSize(item.width, item.height);
    return (
      <a
        href={`${item.imageUrl}${item.imageUrl.includes('?') ? '&' : '?'}tr=w-1600`}
        data-pswp-width={size.w ?? 0}
        data-pswp-height={size.h ?? 0}
        class="gallery-card"
      >
        {item.imageUrl && (
          <Image
            src={item.imageUrl}
            width={400}
            height={300}
            alt={item.alt}
            layout="constrained"
            loading="lazy"
            decoding="async"
            cdn="cloudflare"
            options={{ cloudflare: { domain: "media.quofai.org" } }}
          />
        )}
      </a>
    );
  })}
</div>