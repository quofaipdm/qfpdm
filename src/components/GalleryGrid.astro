---
import { Image } from 'astro:assets';

const { items } = Astro.props;
// items: Array<{ imageUrl: string; alt: string; width?: number; height?: number }>
---

<div class="gallery-grid pswp-gallery" id="gallery">
  {items.map((item) => (
    <a
      href={`${item.imageUrl}${item.imageUrl.includes('?') ? '&' : '?'}tr=w-800`}
      data-pswp-width={item.width ?? 0}
      data-pswp-height={item.height ?? 0}
      class="gallery-card"
    >
      {item.imageUrl && (
        <Image
          src={item.imageUrl}
          width={400}
          height={300}
          alt={item.alt}
          layout="constrained"
          loading="lazy"
          decoding="async"
          transformation={[{ width: 400, height: 300, quality: 80 }]}
        />
      )}
    </a>
  ))}
</div>

<script>
  import PhotoSwipeLightbox from 'photoswipe/lightbox';
  import 'photoswipe/style.css';

  function initLightbox() {
    const gallery = document.getElementById('gallery');
    if (!gallery) return;

    document.querySelectorAll<HTMLAnchorElement>('a.gallery-card').forEach((a) => {
      if (a.dataset.pswpWidth === '0' || a.dataset.pswpHeight === '0') {
        const img = a.querySelector('img');
        if (img) {
          const set = () => {
            if (img.naturalWidth) {
              a.dataset.pswpWidth  = String(img.naturalWidth);
              a.dataset.pswpHeight = String(img.naturalHeight);
            }
          };
          img.complete ? set() : img.addEventListener('load', set);
        }
      }
    });

    const lightbox = new PhotoSwipeLightbox({
      gallery: '#gallery',
      children: 'a',

      initialZoomLevel: 'fill',
      secondaryZoomLevel: 1,
      maxZoomLevel: 2,
      
      pswpModule: () => import('photoswipe'),
    });

    document.addEventListener('astro:before-swap', () => {
      lightbox.destroy();
    });

    lightbox.init();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initLightbox);
  } else {
    initLightbox();
  }
</script>