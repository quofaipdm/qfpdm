---
import { Image } from 'astro:assets';

const { items } = Astro.props;

function getImageSize(w: number | undefined, h: number | undefined) {
  if (w && h) {
    const targetW = Math.min(800, w);
    return { w: targetW, h: Math.round(h * (targetW / w)) };
  }
  return { w: undefined, h: undefined };
}
---

<div class="gallery-grid pswp-gallery" id="gallery">
  {items.map((item) => {
    const size = getImageSize(item.width, item.height);
    return (
      <a
        href={`${item.imageUrl}${item.imageUrl.includes('?') ? '&' : '?'}tr=w-800`}
        data-pswp-width={size.w ?? 0}
        data-pswp-height={size.h ?? 0}
        class="gallery-card"
      >
        {item.imageUrl && (
          <Image
            src={item.imageUrl}
            width={400}
            height={300}
            alt={item.alt}
            layout="constrained"
            loading="lazy"
            decoding="async"
            transformation={[{ width: 400, height: 300, quality: 80 }]}
          />
        )}
      </a>
    );
  })}
</div>

<script>
  import PhotoSwipeLightbox from 'photoswipe/lightbox';
  import 'photoswipe/style.css';

  function initLightbox() {
    const gallery = document.getElementById('gallery');
    if (!gallery) return;

    const cards = document.querySelectorAll<HTMLAnchorElement>('a.gallery-card');

    cards.forEach((a) => {
      if (a.dataset.pswpWidth === '0' || a.dataset.pswpHeight === '0') {
        const img = new Image();
        img.onload = () => {
          a.dataset.pswpWidth = String(img.naturalWidth);
          a.dataset.pswpHeight = String(img.naturalHeight);
        };
        img.src = a.href;
      }
    });

    const lightbox = new PhotoSwipeLightbox({
      gallery: '#gallery',
      children: 'a',

      initialZoomLevel: 'fill',
      secondaryZoomLevel: (z) => z.fit,
      maxZoomLevel: (z) => z.fill * 2,

      pswpModule: () => import('photoswipe'),
    });

    document.addEventListener('astro:before-swap', () => {
      lightbox.destroy();
    });

    lightbox.init();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initLightbox);
  } else {
    initLightbox();
  }
</script>