---
import '../styles/global.css';
import { SEO } from 'astro-seo';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Site de l'association Quo Faï Pas De Mau" } = Astro.props;
const DEFAULT_THEME = 'light';
---

<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Source+Serif+4:ital,opsz,wght@0,8..60,300;0,8..60,400;0,8..60,500;0,8..60,600;0,8..60,700;1,8..60,300;1,8..60,400;1,8..60,500;1,8..60,600;1,8..60,700&family=Inter:wght@400;500;600;700&family=Playfair+Display:ital@0;1&family=Bangers&family=Ultra&family=Bebas+Neue&family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,400;1,9..144,500;1,9..144,600;1,9..144,700&display=swap"
      rel="stylesheet"
    />

    <script is:inline define:vars={{ DEFAULT_THEME }}>
      (function () {
        var stored = null;
        try { stored = localStorage.getItem('theme'); } catch (e) {}
        var theme = stored;
        if (!theme) {
          try {
            theme = window.matchMedia('(prefers-color-scheme: dark)').matches
              ? 'dark'
              : DEFAULT_THEME;
          } catch (e) {
            theme = DEFAULT_THEME;
          }
        }
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>

    <SEO title={title} description={description} />
    <link rel="sitemap" href="/sitemap-index.xml" />
  </head>
  <body class="site-wrapper">
    <Header />
    <main class="site-main">
      <slot />
    </main>
    <Footer />

    <script>
      import PhotoSwipeLightbox from 'photoswipe/lightbox';
      import 'photoswipe/style.css';

      const instances: PhotoSwipeLightbox[] = [];

      function wrapImagesWithLinks(gallery: HTMLElement) {
        const imgs = gallery.querySelectorAll<HTMLImageElement>(':scope > img');
        imgs.forEach((img) => {
          // build mode: url attr has original URL (Astro image service sets it)
          // dev mode: fall back to src (which is the original URL in dev)
          const src = img.getAttribute('url') || img.getAttribute('src');
          if (!src || !src.includes('media.quofai.org')) return;
          const sep = src.includes('?') ? '&' : '?';
          const href = src + sep + 'tr=w-1600';
          const a = document.createElement('a');
          a.href = href;
          a.dataset.pswpWidth = '0';
          a.dataset.pswpHeight = '0';
          img.parentNode!.replaceChild(a, img);
          a.appendChild(img);
        });
      }

      function initLightboxes() {
        const galleries = document.querySelectorAll<HTMLElement>('.pswp-gallery');

        galleries.forEach((gallery) => {
          const id = gallery.id;
          if (!id) return;

          wrapImagesWithLinks(gallery);

          const cards = gallery.querySelectorAll<HTMLAnchorElement>(':scope > a');

          cards.forEach((a) => {
            if (a.dataset.pswpWidth === '0' || a.dataset.pswpHeight === '0') {
              const img = new Image();
              img.onload = () => {
                a.dataset.pswpWidth = String(img.naturalWidth);
                a.dataset.pswpHeight = String(img.naturalHeight);
              };
              img.src = a.href;
            }
          });

          const lightbox = new PhotoSwipeLightbox({
            gallery: `#${id}`,
            children: 'a',

            initialZoomLevel: 'fill',
            secondaryZoomLevel: (z) => z.fit,
            maxZoomLevel: (z) => z.fill * 2,

            pswpModule: () => import('photoswipe'),
          });

          instances.push(lightbox);
          lightbox.init();
        });
      }

      document.addEventListener('astro:before-swap', () => {
        instances.forEach((lb) => lb.destroy());
        instances.length = 0;
      });

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initLightboxes);
      } else {
        initLightboxes();
      }
    </script>
  </body>
</html>
