---
import { getCollection, render } from 'astro:content';
import { YouTube, Vimeo } from 'astro-embed';
import Layout from '@layouts/Layout.astro';
import Hero from '@components/Hero.astro';
import GalleryGrid from '@components/GalleryGrid.astro';
import { resolveGalleryRefs, type GallerySection } from '@utils/gallery';

const articles = (await getCollection('articles', ({ data }) => !data.draft && data.category === 'news'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const latest = articles[0] ?? null;

const isYouTube = (url: string) =>
  url.includes('youtube.com') || url.includes('youtu.be');

const renderedArticles = await Promise.all(
  articles.map(async (a) => {
    const { Content } = await render(a);
    const gallerySections: GallerySection[] = a.data.galleryRef
      ? await resolveGalleryRefs(a.data.galleryRef)
      : [];
    return { article: a, Content, gallerySections, id: a.id };
  })
);
---

<Layout title="Accueil — Quo Faï Pas De Mau" description="Site de l'association Quo Faï Pas De Mau">
  <Hero
    title="Quo Faï Pas De Mau"
    subtitle="Association culturelle en Limousin"
   
  />

  <section class="section">
    <h2 class="content-title">Actualités</h2>

    {renderedArticles.length === 0 && <p>Aucun article pour le moment.</p>}

    {renderedArticles.map(({ article, Content, gallerySections, id }, i) => (
      <article class="news-article">
        <header class="news-article-header">
          <h3 class="news-article-title">
            <a href={`/articles/${id}`}>{article.data.title}</a>
          </h3>
          <p class="news-article-date">
            <time>
              {article.data.date.toLocaleDateString('fr-FR', {
                year: 'numeric', month: 'long', day: 'numeric',
              })}
            </time>
          </p>
        </header>

        {article.data.videoUrl && (
          <div class="news-article-video">
            {isYouTube(article.data.videoUrl)
              ? <YouTube id={article.data.videoUrl} />
              : <Vimeo id={article.data.videoUrl} />}
          </div>
        )}

        {article.body?.trim().length > 0 && (
          <div class="prose">
            <Content />
          </div>
        )}

        {gallerySections.map((section) => (
          <section class="article-gallery">
            <h4>{section.title}</h4>
            <GalleryGrid items={section.images} galleryId={`${id}-${section.id}`} />
          </section>
        ))}

        {i < renderedArticles.length - 1 && <hr class="news-article-separator" />}
      </article>
    ))}
  </section>
</Layout>

<style>
  .section {
    padding-block: var(--spacing-xl);
  }

  .news-article {
    margin-bottom: var(--spacing-2xl);
  }

  .news-article-header {
    max-width: 70ch;
    margin-inline: auto;
    margin-bottom: var(--spacing-lg);
    text-align: center;
  }

  .news-article-title {
    font-size: 1.5rem;
    font-weight: 400;
    font-family: var(--font-display);
    line-height: 1.2;
    margin-bottom: var(--spacing-xs);
  }

  .news-article-title a {
    text-decoration: none;
    color: var(--color-text);

    &:hover {
      color: var(--color-primary);
    }
  }

  .news-article-date {
    font-size: 0.875rem;
    color: var(--color-text-light);
    text-align: center;
  }

  .news-article-video {
    margin-bottom: var(--spacing-lg);
    border-radius: var(--border-radius-lg);
    overflow: hidden;
  }

  .news-article-separator {
    border: none;
    border-top: 1px solid var(--color-border);
    margin-block: var(--spacing-2xl);
  }
</style>
