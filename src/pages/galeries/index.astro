---
import { getCollection } from 'astro:content';
import Layout from '@layouts/Layout.astro';
import CardCover from '@components/CardCover.astro';

const galleries = (await getCollection('galleries', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="Galeries — Quo Faï Pas De Mau" description="Les galeries photos">
  <header class="content-header">
    <h1 class="content-title">Galeries</h1>
  </header>

  {galleries.length === 0 && <p>Aucune galerie pour le moment.</p>}

  <div class="galleries-grid">
    {galleries.map((g) => (
      <a href={`/galeries/${g.id}`} class="gallery-cover-link">
        <CardCover
          src={g.data.cover}
          alt={g.data.title}
          width={g.data.coverWidth}
          height={g.data.coverHeight}
          aspectRatio={4 / 3}
        />
        <div class="gallery-cover-info">
          <h2 class="gallery-cover-title">{g.data.title}</h2>
          {/* <time class="gallery-cover-date">
            {g.data.date.toLocaleDateString('fr-FR', {
              year: 'numeric', month: 'long', day: 'numeric',
            })}
          </time> */}
        </div>
      </a>
    ))}
  </div>
</Layout>
