---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '@layouts/Layout.astro';

const galleries = (await getCollection('galleries', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="Galeries — Quo Faï Pas De Mau" description="Toutes les galeries photos de l'association">
  <h1 class="content-title">Galeries</h1>

  {galleries.length === 0 && <p>Aucune galerie pour le moment.</p>}

  <div class="galleries-grid">
    {galleries.map((g) => (
      <a href={`/galeries/${g.id}`} class="gallery-cover-link">
        <Image
          src={g.data.cover}
          width={800}
          height={600}
          alt={g.data.title}
          layout="constrained"
          loading="lazy"
          transformation={[{ width: 800, height: 600, quality: 85 }]}
        />
        <div class="gallery-cover-info">
          <h2 class="gallery-cover-title">{g.data.title}</h2>
          <time class="gallery-cover-date">
            {g.data.date.toLocaleDateString('fr-FR', {
              year: 'numeric', month: 'long', day: 'numeric',
            })}
          </time>
        </div>
      </a>
    ))}
  </div>
</Layout>
