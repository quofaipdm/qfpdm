---
import { getCollection, render } from 'astro:content';
import { Image } from '@unpic/astro';
import Layout from '@layouts/Layout.astro';
import GalleryGrid from '@components/GalleryGrid.astro';
import { parseGalleryImages } from '@utils/gallery';

export async function getStaticPaths() {
  const galleries = await getCollection('galleries', ({ data }) => !data.draft);
  return galleries.map((g) => ({
    params: { id: g.id },
    props: { gallery: g },
  }));
}

const { gallery } = Astro.props;
const { data } = gallery;
const { Content } = await render(gallery);

const rawImages = parseGalleryImages(data.images, data.title);

const hasBody = gallery.body?.trim().length > 0;
---

<Layout title={`${data.title} — Galeries`} description={data.description}>
  <article>
    <header class="content-header">
      <h1 class="content-title">{data.title}</h1>
      {data.description && <p class="content-description">{data.description}</p>}
      <!-- <p class="content-meta">
        {data.date.toLocaleDateString('fr-FR', {
          year: 'numeric', month: 'long', day: 'numeric',
        })}
      </p> -->
    </header>

    <!-- {data.cover && (
      <Image
        src={data.cover}
        width={1200}
        height={600}
        alt={data.title}
        layout="full-width"
        priority
        cdn="cloudflare"
        options={{ cloudflare: { domain: "media.quofai.org" } }}
      />
    )} -->

    {hasBody && (
      <div class="prose">
        <Content />
      </div>
    )}

    {rawImages.length > 0
      ? <GalleryGrid items={rawImages} />
      : !hasBody && <p>Aucune image dans cette galerie.</p>}
  </article>
</Layout>
