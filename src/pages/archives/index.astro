---
import { getCollection } from 'astro:content';
import Layout from '@layouts/Layout.astro';
import CardCover from '@components/CardCover.astro';

const articles = (await getCollection('articles', ({ data }) => !data.draft && data.category === 'archives'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const galleries = (await getCollection('galleries', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="Les archives — Quo Faï Pas De Mau" description="Archives de l'association Quo Faï Pas De Mau">
  <header class="content-header">
    <h1 class="content-title">Les archives</h1>
    <p class="content-description">
      Retrouvez ici les archives de l'association : anciens événements, articles historiques et souvenirs.
    </p>
  </header>

  {articles.length > 0 && (
    <section>
      <h2 class="section-heading">Articles archivés</h2>
      <div class="galleries-grid">
        {articles.map((a) => (
          <a href={`/archives/${a.id}`} class="card">
          <CardCover
            src={a.data.cover}
            alt={a.data.title}
            width={a.data.coverWidth}
            height={a.data.coverHeight}
            aspectRatio={16 / 9}
          />
            <div class="card-body">
              <h2 class="card-title">{a.data.title}</h2>
              {a.data.description && <p class="card-description">{a.data.description}</p>}
              <div class="card-meta">
                {/* <time>
                  {a.data.date.toLocaleDateString('fr-FR', {
                    year: 'numeric', month: 'long', day: 'numeric',
                  })}
                </time> */}
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <section class="archives-galleries">
    <h2 class="section-heading">Galeries photos</h2>
    <p class="content-description">
      Toutes les galeries photos de l'association, des premières rencontres aux événements récents.
    </p>
    <a href="/galeries" class="btn btn-primary">Voir toutes les galeries</a>

    <div class="galleries-grid" style="margin-top: var(--spacing-lg)">
      {galleries.slice(0, 3).map((g) => (
        <a href={`/galeries/${g.id}`} class="gallery-cover-link">
          <CardCover
            src={g.data.cover}
            alt={g.data.title}
            width={g.data.coverWidth}
            height={g.data.coverHeight}
            aspectRatio={4 / 3}
          />
          <div class="gallery-cover-info">
            <h3 class="gallery-cover-title">{g.data.title}</h3>
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>

<style>
  .section-heading {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    margin-bottom: var(--spacing-lg);
    margin-top: var(--spacing-2xl);
    color: var(--color-text);
  }

  .archives-galleries {
    margin-top: var(--spacing-xl);
    padding-top: var(--spacing-xl);
    border-top: 1px solid var(--color-border);
  }
</style>
