---
import { getCollection, render } from 'astro:content';
import { Image } from '@unpic/astro';
import { YouTube, Vimeo } from 'astro-embed';
import Layout from '@layouts/Layout.astro';
import GalleryGrid from '@components/GalleryGrid.astro';
import { resolveGalleryRefs, type GallerySection } from '@utils/gallery';

export async function getStaticPaths() {
  const articles = await getCollection('articles', ({ data }) => !data.draft && data.category === 'birbizis');
  return articles.map((a) => ({
    params: { id: a.id },
    props: { article: a },
  }));
}

const { article } = Astro.props;
const { data } = article;
const { Content } = await render(article);

const isYouTube = (url: string) =>
  url.includes('youtube.com') || url.includes('youtu.be');

const hasBody = article.body?.trim().length > 0;

const gallerySections: GallerySection[] = data.galleryRef
  ? await resolveGalleryRefs(data.galleryRef)
  : [];
---

<Layout title={`${data.title} — Birbizis`} description={data.description}>
  <article>
    <header class="content-header">
      <h1 class="content-title">{data.title}</h1>
      {data.description && <p class="content-description">{data.description}</p>}
      <!-- <p class="content-meta">
        {data.date.toLocaleDateString('fr-FR', {
          year: 'numeric', month: 'long', day: 'numeric',
        })}
      </p> -->
    </header>

    <!-- {data.cover && (
      <Image
        src={data.cover}
        width={1200}
        height={600}
        alt={data.title}
        layout="full-width"
        priority
        cdn="cloudflare"
        options={{ cloudflare: { domain: "media.quofai.org" } }}
      />
    )} -->

    {data.videoUrl && (
      <div class="article-video">
        {isYouTube(data.videoUrl)
          ? <YouTube id={data.videoUrl} />
          : <Vimeo id={data.videoUrl} />}
      </div>
    )}

    {hasBody && (
      <div class="prose">
        <Content />
      </div>
    )}

    {gallerySections.map((section) => (
      <section class="article-gallery">
        <h2>{section.title}</h2>
        <GalleryGrid items={section.images} galleryId={section.id} />
      </section>
    ))}
  </article>
</Layout>
