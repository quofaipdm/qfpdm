---
import { getCollection } from 'astro:content';
import Layout from '@layouts/Layout.astro';
import CardCover from '@components/CardCover.astro';

const articles = (await getCollection('articles', ({ data }) => !data.draft && data.category === 'birbizis'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="Les Birbizis — Quo Faï Pas De Mau" description="Les Birbizis, nos rencontres annuelles">
  <header class="content-header">
    <h1 class="content-title">Les Birbizis</h1>
    <p class="content-description">
      Les Birbizis sont nos rencontres annuelles autour de la jongle, de la musique et du partage.
      Découvrez les éditions précédentes.
    </p>
  </header>

  {articles.length === 0 && <p>Aucune birbizi pour le moment.</p>}

  <div class="galleries-grid">
    {articles.map((a) => (
      <a href={`/birbizis/${a.id}`} class="card">
        <CardCover
          src={a.data.cover}
          alt={a.data.title}
          width={a.data.coverWidth}
          height={a.data.coverHeight}
          aspectRatio={16 / 9}
        />
        <div class="card-body">
          <h2 class="card-title">{a.data.title}</h2>
          {a.data.description && <p class="card-description">{a.data.description}</p>}
          <div class="card-meta">
            {/* <time>
              {a.data.date.toLocaleDateString('fr-FR', {
                year: 'numeric', month: 'long', day: 'numeric',
              })}
            </time> */}
          </div>
        </div>
      </a>
    ))}
  </div>
</Layout>
